/*
The Problem No One Is Solving

Every AAA engine running on a handheld today is fighting the same war on two fronts simultaneously:
the CPU is trying to simulate physics and stream assets while the GPU is trying to render frames,
and both are competing for the same LPDDR5X bandwidth pipe on the same thermal envelope.

The standard industry answer is "buy more watts." On a 35W APU, that answer does not exist.

DVSM-π+++ is a zero-heap, bit-identical dynamical kernel that runs inside iGPU execution bubbles
and performs continuous spectral diagnostics on the engine's state space.
It does not ask for more power. It uses power that was already being wasted.
*/

#![no_std]
#![allow(non_snake_case)]
#![allow(clippy::excessive_precision)]

use core::f32::consts::PI;

// =============================================================================
// CORE EQUATION (documented form)
// =============================================================================
/*
dZ_k/dt = Σ_j κ_{kj}(Z_k·S_j − Z_j·S_k) − λ·Z_k + B_k

B_k = −α(‖Z‖² − E_target)·Z_k
*/

// =============================================================================
// CONSTANTS
// =============================================================================

pub const DIM: usize = 16;

pub const Q31_SCALE: f32 = 2_147_483_648.0;

// =============================================================================
// WATTAGE PROFILE
// =============================================================================

#[repr(C)]
#[derive(Clone, Copy, Debug)]
pub struct WattageProfile {
    pub tdp_watts: f32,
    pub dt: f32,
    pub lambda: f32,
    pub alpha: f32,
    pub e_target: f32,
    pub ema_beta: f32,
}

impl WattageProfile {
    pub const ALLY_X_PERF: Self = Self {
        tdp_watts: 35.0,
        dt: 1.0 / 240.0,
        lambda: 0.12,
        alpha: 0.08,
        e_target: 1.0,
        ema_beta: 0.95,
    };

    pub const ALLY_X_BALANCED: Self = Self {
        tdp_watts: 25.0,
        dt: 1.0 / 120.0,
        lambda: 0.10,
        alpha: 0.06,
        e_target: 1.0,
        ema_beta: 0.93,
    };
}

// =============================================================================
// STATE
// =============================================================================

#[repr(C)]
#[derive(Clone, Copy, Debug)]
pub struct DVSMState {
    pub z: [f32; DIM],
    pub s: [f32; DIM],
    pub kappa: [f32; DIM * DIM],
    pub norm_sq: f32,
    pub replay_hash: u64,
}

impl DVSMState {
    pub fn new() -> Self {
        Self {
            z: [0.0; DIM],
            s: [0.0; DIM],
            kappa: [0.0; DIM * DIM],
            norm_sq: 0.0,
            replay_hash: 0,
        }
    }

    #[inline]
    pub fn kappa_get(&self, k: usize, j: usize) -> f32 {
        self.kappa[k * DIM + j]
    }

    #[inline]
    pub fn update_norm(&mut self) {
        self.norm_sq = self.z.iter().map(|x| x * x).sum();
    }
}

// =============================================================================
// CORE KERNEL STEP
// =============================================================================

pub fn dvsm_step(state: &mut DVSMState, p: &WattageProfile) {
    let mut acc = [0.0_f32; DIM];

    for k in 0..DIM {
        let zk = state.z[k];
        let sk = state.s[k];

        for j in 0..DIM {
            if j == k { continue; }

            let bracket = zk * state.s[j] - state.z[j] * sk;
            acc[k] += state.kappa_get(k, j) * bracket;
        }
    }

    let backreaction_coeff = -p.alpha * (state.norm_sq - p.e_target);

    for k in 0..DIM {
        let b_k = backreaction_coeff * state.z[k];
        let dz = p.dt * (acc[k] - p.lambda * state.z[k] + b_k);

        state.z[k] += dz;

        state.s[k] = p.ema_beta * state.s[k] + (1.0 - p.ema_beta) * state.z[k];
    }

    state.update_norm();
}

// =============================================================================
// REPLAY HASH (Q31 deterministic fold)
// =============================================================================

impl DVSMState {
    pub fn update_replay_hash(&mut self) {
        let mut h: u64 = self.replay_hash;

        for k in 0..DIM {
            let clamped = self.z[k].clamp(-1.0 + 1e-7, 1.0 - 1e-7);
            let q = (clamped * Q31_SCALE) as i32 as u64;

            h ^= q
                .wrapping_mul(0x9e3779b97f4a7c15)
                .wrapping_add(k as u64);
        }

        self.replay_hash = h;
    }
}

